<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotell.Views.HomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F2F2F2">

    <VerticalStackLayout
        Padding="25,60,25,25"
        Spacing="25">

        <Frame Padding="20"
               CornerRadius="20"
               BackgroundColor="#1E3A8A"
               HasShadow="True">

            <VerticalStackLayout>

                <Label Text="Meu App Hotel"
                       FontSize="32"
                       FontFamily="Exo2ExtraLight"
                       TextColor="White"
                       HorizontalOptions="Center"
                       FontAttributes="Bold"/>

            </VerticalStackLayout>

        </Frame>

        <Button Text="Hospedagem"
                Clicked="OnHospedagemClicked"
                BackgroundColor="#2563EB"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="55"/>

        <Button Text="Sobre o App"
                Clicked="OnSobreClicked"
                BackgroundColor="#2563EB"
                TextColor="White"
                CornerRadius="15"
                HeightRequest="55"/>

    </VerticalStackLayout>

</ContentPage>